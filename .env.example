# beliq CLI configuration. Every setting also has a flag that overrides it.

# Required (or pass --api-key). Create a key in the beliq dashboard under API Keys.
BELIQ_API_KEY=

# Optional (or pass --auth). How the key is sent: "header" (X-API-Key, default)
# or "bearer" (Authorization: Bearer).
BELIQ_AUTH=header

# Optional (or pass --base-url). Override only for a self-hosted deployment;
# defaults to the production API.
BELIQ_BASE_URL=https://api.beliq.eu
