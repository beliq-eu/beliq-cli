{
  "name": "beliq-cli",
  "version": "0.2.0",
  "description": "beliq CLI: validate, generate, parse, and convert EU e-invoices (XRechnung, ZUGFeRD, Factur-X, Peppol BIS) against authority-pinned, drift-checked rules, from the terminal or CI.",
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "beliq",
    "email": "hello@beliq.eu"
  },
  "homepage": "https://beliq.eu",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beliq-eu/beliq-cli.git"
  },
  "bugs": {
    "url": "https://github.com/beliq-eu/beliq-cli/issues"
  },
  "keywords": [
    "beliq",
    "cli",
    "e-invoice",
    "einvoice",
    "xrechnung",
    "zugferd",
    "factur-x",
    "peppol",
    "en16931",
    "validation",
    "compliance",
    "ci"
  ],
  "engines": {
    "node": ">=20.15"
  },
  "bin": {
    "beliq": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "provenance": true
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest run --exclude test/integration.test.ts",
    "test:integration": "vitest run test/integration.test.ts",
    "scrub:check": "bash scripts/scrub-check.sh",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@beliq/sdk": "^0.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.8"
  }
}
